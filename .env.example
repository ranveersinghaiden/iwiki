# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=iwiki
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=iwiki
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://iwiki:your_strong_password_here@db:5432/iwiki

# ─── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@your-org.com
JIRA_API_TOKEN=your_jira_api_token_here
# Comma-separated Jira project keys to index
JIRA_PROJECTS=PROJ1,PROJ2

# ─── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
# Comma-separated Confluence space keys to index
CONFLUENCE_SPACES=SPACE1,SPACE2

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# text-embedding-3-small (dim=1536) | text-embedding-ada-002 (dim=1536) | nomic-embed-text via Ollama (dim=768)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# gpt-4o-mini | gpt-4o | ollama model name
LLM_MODEL=gpt-4o-mini
# Set only if using Ollama instead of OpenAI
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=your_strong_admin_key_here

# ─── Ingestion tuning ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_BATCH_SIZE=32
# Cron expression for incremental sync (default: every hour)
SYNC_CRON=0 * * * *

