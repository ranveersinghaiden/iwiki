# iWiki environment configuration — copy to `.env` and fill in real values.
#   cp .env.example .env
# Placeholders only. NEVER commit a real .env (it is gitignored).
# Full reference: README.md § Environment Variables.

# ─── PostgreSQL (docker-compose) ──────────────────────────────────────────────
POSTGRES_USER=iwiki
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=iwiki
POSTGRES_PORT=5432

# Service DB connection (async SQLAlchemy / asyncpg).
# For local (non-Docker) dev use localhost. NOTE: docker-compose overrides this
# at runtime to use host `db`, so this value only matters when running services
# directly on the host.
DATABASE_URL=postgresql+asyncpg://iwiki:your_strong_password_here@localhost:5432/iwiki

# Optional published ports (defaults shown).
INGESTION_PORT=8090
QUERY_PORT=8091

# ─── Admin auth ───────────────────────────────────────────────────────────────
# Required by ingestion-service. Sent as the `X-Admin-Key` header on all
# ingest/expert endpoints. If blank, those endpoints return 503.
ADMIN_API_KEY=your_strong_admin_key_here

# ─── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@your-org.com
JIRA_API_TOKEN=your_jira_api_token_here
# Comma-separated project keys to index. Leave blank to skip Jira.
JIRA_PROJECTS=PROJ1,PROJ2
JIRA_PAGE_SIZE=100

# ─── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
# Comma-separated space keys to index. Leave blank to skip Confluence.
CONFLUENCE_SPACES=SPACE1,SPACE2
CONFLUENCE_PAGE_SIZE=50

# ─── AI provider — choose ONE: Ollama (local) or OpenAI (cloud) ───────────────
# IMPORTANT: EMBEDDING_DIM declares the embedding width you intend to use. It is
# advisory — the system does NOT resize anything from it. The REAL constraint is:
#   embedding-model output dim  ==  db/init.sql `chunks.embedding vector(N)`
# The shipped schema is vector(768). If the two disagree, inserts fail. To change
# width you must ALTER the column AND rebuild the HNSW index (see POSTGRES.md).

# --- Option A: Ollama (local, offline) — matches the shipped vector(768) schema ---
OPENAI_API_KEY=ollama                       # any non-empty value; Ollama ignores it
OLLAMA_BASE_URL=http://localhost:11434/v1   # in Docker use http://host.docker.internal:11434/v1
EMBEDDING_MODEL=nomic-embed-text            # 768-dim
EMBEDDING_DIM=768
LLM_MODEL=llama3.2:3b

# --- Option B: OpenAI (cloud) — REQUIRES schema change to vector(1536) ---
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OLLAMA_BASE_URL=                          # leave blank/unset to use OpenAI
# EMBEDDING_MODEL=text-embedding-3-small    # 1536-dim
# EMBEDDING_DIM=1536                        # also run: ALTER TABLE chunks ALTER COLUMN embedding TYPE vector(1536);
# LLM_MODEL=gpt-4o-mini

# ─── Ingestion tuning ─────────────────────────────────────────────────────────
CHUNK_SIZE=512                # tokens per chunk
CHUNK_OVERLAP=64              # token overlap between chunks
EMBEDDING_BATCH_SIZE=32       # texts per embedding API call
# 5-part cron (min hour day month day_of_week) for automatic incremental sync.
SYNC_CRON=0 * * * *           # hourly

# ─── Product hierarchy / classification ───────────────────────────────────────
# Path (inside the ingestion container) to the taxonomy YAML the classifier uses.
# docker-compose mounts ./product_hierarchy.yaml at /app/product_hierarchy.yaml.
HIERARCHY_CONFIG_PATH=product_hierarchy.yaml
# Classifier cascade thresholds (rule → semantic → LLM).
CLASSIFICATION_RULE_MIN_SCORE=3.0          # min keyword score for the rule stage
CLASSIFICATION_SEMANTIC_FALLBACK=true      # run embedding-similarity stage when rules miss
CLASSIFICATION_SEMANTIC_THRESHOLD=0.45     # min cosine similarity to accept a semantic match
CLASSIFICATION_REVIEW_THRESHOLD=0.5        # below this → result flagged needs_review

# ─── Retrieval (query-service) ────────────────────────────────────────────────
SEARCH_CANDIDATE_LIMIT=20    # candidates pulled from each of the vector + FTS legs
TOP_K_RESULTS=8              # default chunks passed to the LLM (request can override, 1-20)
MAX_QUERY_LENGTH=4096        # max characters in a user query

# ─── Reranking (query-service) ────────────────────────────────────────────────
RERANK_ENABLED=true                  # master switch for the signal-blend rerank stage
RERANK_CANDIDATE_POOL=20             # pool pulled from hybrid search before reranking
# Blend weights (relative; normalised internally). RRF dominates by default.
RERANK_WEIGHT_RRF=0.55
RERANK_WEIGHT_FRESHNESS=0.15
RERANK_WEIGHT_AUTHORITY=0.15
RERANK_WEIGHT_TAXONOMY=0.15
RERANK_FRESHNESS_HALF_LIFE_DAYS=180  # exponential decay half-life for freshness
# Per-source authority weights (0-1).
RERANK_AUTHORITY_CONFLUENCE=1.0
RERANK_AUTHORITY_JIRA=0.7
RERANK_AUTHORITY_DEFAULT=0.6
# Optional LLM rerank applied to the top-N blended candidates (degrades gracefully).
RERANK_LLM_ENABLED=true
RERANK_LLM_TOP_N=10
